{
  "name": "geo-renderer",
  "version": "0.1.0",
  "description": "Lightweight MCP server for geospatial rendering — D3 SVG maps, locator globes, GDAL processing",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "geo-renderer": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "d3": "^7.9.0",
    "jsdom": "^26.1.0",
    "topojson-client": "^3.1.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.15.3",
    "@types/topojson-client": "^3.1.5",
    "typescript": "^5.8.3",
    "vitest": "^2.1.9"
  }
}
